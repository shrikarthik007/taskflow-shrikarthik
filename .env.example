# PostgreSQL
POSTGRES_DB=taskflow
POSTGRES_USER=taskflow
POSTGRES_PASSWORD=taskflow_secret_123

# Backend
DATABASE_URL=postgresql://taskflow:taskflow_secret_123@postgres:5432/taskflow?sslmode=disable
JWT_SECRET=change-this-to-a-long-random-secret-before-production
PORT=4000

# Frontend (used at build time by Vite)
VITE_API_URL=http://localhost:4000
